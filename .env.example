# MIRCrew Proxy - Configurazione
MIRCREW_USERNAME=tuo_username
MIRCREW_PASSWORD=tua_password
MIRCREW_API_KEY=una-chiave-a-tua-scelta

# Cloudflare Bypass - Cookie injection
# Opzione 1: Incolla qui l'export JSON di Cookie Editor (dal browser su mircrew-releases.org)
# CF_COOKIES=[{"name":"cf_clearance","value":"...","domain":".mircrew-releases.org"}]
#
# Opzione 2: Usa POST /cookies endpoint a runtime (vedi README)
#
# User-Agent del browser da cui hai estratto i cookies (DEVE corrispondere!)
# CF_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/134.0.0.0 Safari/537.36

LOG_LEVEL=INFO
