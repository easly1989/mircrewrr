# MIRCrew Proxy - Environment Variables
# Copia questo file in .env e configura le variabili

# Credenziali MIRCrew (OBBLIGATORIO)
MIRCREW_USERNAME=your_username
MIRCREW_PASSWORD=your_password

# URL base del sito
MIRCREW_URL=https://mircrew-releases.org

# API Key per Prowlarr (scegli una chiave sicura)
MIRCREW_API_KEY=mircrew-api-key

# Porta del proxy server
PROXY_PORT=9696

# Byparr/FlareSolverr URL (per bypass Cloudflare)
# Se usi il docker-compose incluso, lascia il default
FLARESOLVERR_URL=http://byparr:8191

# Livello di log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
